# =============================================================================
# PIFinder environment variables
# Copy this file to .env.local for local dev:  cp .env.example .env.local
# NEVER commit .env / .env.local. Only this .example file is tracked in git.
# =============================================================================

# ---- App ----
NEXT_PUBLIC_APP_NAME="PIFinder"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Supabase (managed for MVP) ----
# Found in: Supabase Dashboard > Project Settings > API
# Safe to expose to the browser (anon key is RLS-protected):
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# SERVER-ONLY. NEVER expose to the browser. Bypasses RLS.
# Used only in server actions / API routes / admin scripts.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database connection string (for raw migrations via scripts/db-migrate.mjs).
# Supabase Dashboard > Project Settings > Database > Connection string (URI).
# Use the "Session" pooler or direct connection for migrations.
SUPABASE_DB_URL="postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres"

# ---- Membership gate ----
# Required email domain. Only this domain may sign up (in addition to allowlist).
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN="snu.ac.kr"
# Bootstrap admin emails (comma separated). These are promoted to admin on first login.
BOOTSTRAP_ADMIN_EMAILS="minnyule@snu.ac.kr"

# ---- LLM provider (swappable) ----
# provider: "anthropic" | "openai" | "mock"
LLM_PROVIDER="mock"
LLM_MODEL="claude-opus-4-8"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ---- External professor data sources (Phase 3) ----
# OpenAlex requires no key but asks for a contact email (polite pool).
OPENALEX_MAILTO="minnyule@snu.ac.kr"
# Semantic Scholar API key is optional (raises rate limits).
SEMANTIC_SCHOLAR_API_KEY=""
CROSSREF_MAILTO="minnyule@snu.ac.kr"

# ---- Rate limiting / usage tracking ----
# Max expensive AI/search runs per user per day.
RATE_LIMIT_RUNS_PER_DAY="20"
